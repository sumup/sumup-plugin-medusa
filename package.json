{
  "name": "@sumup/medusa-plugin",
  "version": "0.1.0",
  "description": "SumUp payment provider for Medusa v2.",
  "author": "SumUp <support@sumup.com> (https://sumup.com/)",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "./.medusa/server/src/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sumup/sumup-plugin-medusa.git"
  },
  "homepage": "https://github.com/sumup/sumup-plugin-medusa#readme",
  "bugs": {
    "url": "https://github.com/sumup/sumup-plugin-medusa/issues"
  },
  "packageManager": "yarn@1.22.22",
  "files": [
    ".medusa/server",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "exports": {
    "./package.json": "./package.json",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js"
  },
  "keywords": [
    "medusa",
    "medusa-plugin",
    "medusa-v2",
    "medusa-plugin-integration",
    "medusa-plugin-payment",
    "sumup",
    "payments"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "medusa plugin:build"
  },
  "dependencies": {
    "@sumup/sdk": "^0.1.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@medusajs/cli": "^2.15.5",
    "@medusajs/framework": "^2.15.5",
    "@medusajs/medusa": "^2.15.5",
    "@types/node": "^26.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "@medusajs/framework": "^2.15.5"
  }
}
