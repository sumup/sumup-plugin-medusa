{
  "name": "medusa-plugin-sumup",
  "version": "0.1.0",
  "description": "SumUp online payments provider for Medusa v2.",
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "main": "./.medusa/server/src/index.js",
  "files": [
    ".medusa/server",
    "README.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "keywords": [
    "medusa",
    "medusa-plugin",
    "medusa-v2",
    "medusa-plugin-integration",
    "medusa-plugin-payment",
    "sumup",
    "payments"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "medusa plugin:build"
  },
  "dependencies": {
    "@sumup/sdk": "^0.1.6"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "^2.15.3",
    "@medusajs/cli": "^2.15.3",
    "@medusajs/framework": "^2.15.3",
    "@medusajs/icons": "^2.15.3",
    "@medusajs/medusa": "^2.15.3",
    "@medusajs/test-utils": "^2.15.3",
    "@medusajs/ui": "^4.1.13",
    "@swc/core": "^1.15.40",
    "@types/node": "^25.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "^2.15.3",
    "@medusajs/cli": "^2.15.3",
    "@medusajs/framework": "^2.15.3",
    "@medusajs/icons": "^2.15.3",
    "@medusajs/medusa": "^2.15.3",
    "@medusajs/test-utils": "^2.15.3",
    "@medusajs/ui": "^4.1.13"
  }
}
