# Copy this file to `.env` and fill in your real SumUp credentials:
#   cp example.env .env
#
# Everything below has working local defaults except the SumUp secrets.

# --- SumUp credentials (REQUIRED) ---------------------------------------
# Use a SumUp *sandbox* merchant. The plugin fails to boot without these.
SUMUP_API_KEY=sup_sk_replace_me
SUMUP_MERCHANT_CODE=REPLACE_ME
# "hosted" (redirect to SumUp page) or "widget" (embed card widget)
SUMUP_CHECKOUT_MODE=hosted

# --- Postgres -----------------------------------------------------------
POSTGRES_USER=medusa
POSTGRES_PASSWORD=medusa
POSTGRES_DB=medusa

# --- Medusa secrets -----------------------------------------------------
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# --- URLs / CORS --------------------------------------------------------
# Public URL of the Medusa backend (as seen from your browser/host).
MEDUSA_BACKEND_URL=http://localhost:9000
# Public URL of the minimal storefront.
STOREFRONT_URL=http://localhost:8080
# Backend URL the browser uses to call the Store API (baked into config.json).
STOREFRONT_MEDUSA_URL=http://localhost:9000

STORE_CORS=http://localhost:8080
ADMIN_CORS=http://localhost:9000,http://localhost:8080
AUTH_CORS=http://localhost:9000,http://localhost:8080

# --- Admin user (created automatically on first boot) -------------------
MEDUSA_ADMIN_EMAIL=admin@medusa.local
MEDUSA_ADMIN_PASSWORD=supersecret
