{
  "compilerOptions": {
    "target": "ES2021",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "jsx": "react-jsx",
    "outDir": "./dist",
    "baseUrl": ".",
    "rootDir": "src",
    "lib": ["ES2021"],
    "types": ["node"]
  },
  "include": ["src", ".medusa/types/*", "medusa-config.ts"],
  "exclude": ["node_modules", ".cache", ".medusa/server", "**/*.spec.ts", "dist"]
}
